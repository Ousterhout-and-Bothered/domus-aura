# Local .terraform directories
.terraform/
.terraform.lock.hcl.bak

# Terraform state files (state is in S3, never commit local copies)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json

# CLI configuration
.terraformrc
terraform.rc

# Saved plan files
*.tfplan
*.tfplan.binary
tfplan*